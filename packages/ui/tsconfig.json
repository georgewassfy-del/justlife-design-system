{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "noUncheckedIndexedAccess": false,
    "skipLibCheck": true,
    "noEmit": true,
    "moduleResolution": "Bundler"
  },
  "include": ["src", "vitest.config.ts", "vitest.setup.ts"],
  "exclude": ["**/*.stories.tsx", "dist"]
}
