{
  "name": "justlife-design-system",
  "version": "0.0.0",
  "private": true,
  "description": "Justlife Design System — code-based tokens, components, and prototyping platform.",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "tokens:build": "pnpm --filter @justlife/tokens build",
    "tokens:import": "pnpm --filter @justlife/tokens run import",
    "figma:inventory": "pnpm --filter @justlife/figma-sync run inventory",
    "storybook": "pnpm --filter @justlife/storybook dev",
    "storybook:build": "pnpm --filter @justlife/storybook build",
    "new:component": "plop --plopfile tools/generators/plopfile.mjs component",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "eslint-plugin-justlife": "workspace:*",
    "plop": "^4.0.1",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^18.3.18"
    }
  }
}
